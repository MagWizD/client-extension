{
  "name": "open-prompt",
  "displayName": "open-prompt",
  "description": "AI-code logging, tagging, and checking",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onChatParticipant:open-prompt"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "open-prompt.helloWorld",
        "title": "Hello World"
      }
    ],
    "chatParticipants": [
      {
        "id": "open-prompt",
        "name": "OpenPrompt",
        "description": "Chats and auto-saves history to Git commits"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  }
}
